---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav";
import Footer from "../../components/Footer";
import RenewalHero from "../../components/products/RenewalHero";
import RenewalFlip from "../../components/products/RenewalFlip";
import RenewalFeatures from "../../components/products/RenewalFeatures";
import RenewalCompare from "../../components/products/RenewalCompare";
import RenewalBottomCTA from "../../components/products/RenewalBottomCTA";
---

<Base
  title="RenewalEngine · IP Renewals That Generate Margin"
  description="Automated IP renewals across 190+ jurisdictions. Full cost transparency. 27.7% average savings vs traditional providers. Keep client ownership — run on automated infrastructure."
>
  <Nav client:load />
  <main>
    <RenewalHero client:load />
    <RenewalFlip client:visible />
    <RenewalFeatures client:visible />
    <RenewalCompare client:visible />
    <RenewalBottomCTA client:visible />
  </main>
  <Footer />
</Base>
