---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav";
import Footer from "../../components/Footer";
import BlogIndex from "../../components/blog/BlogIndex";
import { getAllPosts, getLatestPosts } from "../../lib/posts";

const allPosts = await getAllPosts();
const latestPosts = await getLatestPosts(3);

const posts = allPosts.map((p) => ({
  slug:       p.slug,
  title:      p.title,
  dateISO:    p.date.toISOString(),
  dateFmt:    p.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }),
  author:     p.author,
  category:   p.category,
  excerpt:    p.excerpt,
  coverColor: p.coverColor,
  coverImage: p.coverImage,
  readTime:   p.readTime,
}));
---

<Base
  title="Insights · Guarded Growth Blog"
  description="Insights for IP practitioners — docketing, renewals, IP strategy, and product updates from the team building the data infrastructure layer for global IP."
>
  <Nav client:load latestPosts={latestPosts} />
  <main>

    {/* Hero */}
    <section style="padding-top: 120px; padding-bottom: 56px; position: relative; overflow: hidden; background: #050510;">
      <div style="position: absolute; width: 700px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(45,42,110,0.45) 0%, transparent 65%); top: -10%; left: 50%; transform: translateX(-50%); filter: blur(80px);"></div>
      <div class="grid-bg-animated" style="position: absolute; inset: 0;"></div>

      <div class="max-w-content mx-auto px-7 relative">
        <div style="max-width: 720px;">
          <span style="font-size: 12px; font-weight: 700; letter-spacing: 0.1em; color: #5B7FFF; text-transform: uppercase; display: block; margin-bottom: 18px;">Blog & Insights</span>
          <h1 class="font-display font-extrabold text-white" style="font-size: clamp(40px, 5vw, 60px); letter-spacing: -0.04em; line-height: 1.05; margin-bottom: 18px;">
            Insights for IP practitioners.
          </h1>
          <p style="font-size: 18px; line-height: 1.7; color: rgba(255,255,255,0.5); font-family: 'General Sans', sans-serif; max-width: 600px;">
            Practical writing on docketing, renewals, IP strategy, and the infrastructure underneath. From the team building the modern IP management stack.
          </p>
        </div>
      </div>
    </section>

    <BlogIndex client:load posts={posts} />
  </main>
  <Footer />
</Base>
