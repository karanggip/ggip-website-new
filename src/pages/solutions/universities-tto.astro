---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav";
import Footer from "../../components/Footer";
import SolutionTemplate from "../../components/solutions/SolutionTemplate";
---

<Base
  title="For Universities & TTOs · Patent Renewal Savings + Trademark Docketing"
  description="Cut patent renewal costs at TTO scale. Trademark docketing for university brands and spinouts. Education pricing. Stakeholder-ready reporting."
>
  <Nav client:load />
  <main>
    <SolutionTemplate client:visible config={{
      audienceIcon: "graduation",
      eyebrow: "For Universities & TTOs",
      headline: "Cut your patent renewal costs. Build toward a unified TTO platform.",
      subheadline: "Built for university technology transfer offices: meaningful renewal savings on your patent portfolio today, trademark docketing for your university's brands and spinouts, and a roadmap toward end-to-end IP management your office helps shape.",
      accent: { c: "#4A47A3", rgb: "74,71,163", gradFrom: "#EEEDFA", gradTo: "#E0DCFA" },
      painPoints: [
        {
          icon: "file",
          title: "Manual disclosure intake doesn't scale.",
          body: "Faculty submit inventions via paper forms, email, and Word docs. You can't track them centrally, and high-value disclosures get lost in your inbox.",
        },
        {
          icon: "dollar",
          title: "Limited budget. Procurement-heavy buying cycle.",
          body: "Six-figure enterprise IP platforms aren't going to clear committee. You need real software, sized for an academic operations budget.",
        },
        {
          icon: "chart",
          title: "Stakeholder reporting is exhausting.",
          body: "The Provost wants one view. Industry sponsors want another. NIH and NSF auditors want a third. Each one currently takes days of manual exporting.",
        },
      ],
      solution: {
        headline: "Modern IP infrastructure for TTOs — sized for academia.",
        intro: "Start where the savings are biggest: patent and trademark renewals. Add live trademark docketing for your university's brand and spinouts. Generate stakeholder reports in minutes. And help us shape patent docketing and invention disclosure as we build them.",
        capabilities: [
          {
            icon: "renewal",
            title: "Patent renewal savings at TTO scale",
            body: "RenewalEngine handles patent and trademark renewals across 100+ jurisdictions with transparent pricing and no opaque markups. For a typical TTO portfolio, that translates into meaningful budget recovered every year — money you can redirect to filings, IP analysis, or the next disclosure round.",
          },
          {
            icon: "engine",
            title: "Trademark docketing for university brands",
            body: "DocketEngine handles your university's branded marks, research center names, and spinout trademarks. Real-time sync with USPTO and major trademark offices — no manual status checking, no calendar drift.",
          },
          {
            icon: "chart",
            title: "Stakeholder-ready reports",
            body: "Pre-built views for Provost, sponsors, and audit purposes. Custom exports for grant reporting. The reports your office runs every quarter — without the weekly prep work.",
          },
          {
            icon: "graduation",
            title: "Education pricing + roadmap partnership",
            body: "Discounted pricing for accredited universities and non-profit research institutions. Patent docketing and faculty invention intake are on our roadmap — TTOs that come aboard early help shape what we build.",
          },
        ],
      },
      proofPoints: [
        { value: "100+",       label: "Jurisdictions for renewals" },
        { value: "Patent + TM", label: "Renewal coverage today" },
        { value: "Education",  label: "Pricing for universities & non-profits" },
        { value: "Roadmap",    label: "Patent docketing & invention intake" },
      ],
      recommendation: {
        plan: "RenewalEngine + DocketEngine Start",
        price: "Custom",
        period: "(Education pricing on request)",
        reasoning: "For TTOs ready to capture renewal savings today, plus trademark docketing for university brands and spinouts. Education pricing on request — the effective cost typically lands meaningfully below list.",
        href: "/pricing",
        bullets: [
          "Patent + trademark renewals across 100+ jurisdictions",
          "Trademark docketing for university marks & spinouts",
          "Custom reporting & exports for sponsor and audit reviews",
          "Education pricing on request",
          "Roadmap partnership on patent docketing & invention intake",
          "Priority support",
        ],
      },
      bottomCTA: {
        headline: "Talk to us about your TTO.",
        subheadline: "Most universities can capture material renewal savings in their first year — and we'll walk you through trademark docketing and what the roadmap looks like for your office. Education pricing for accredited institutions and non-profits.",
      },
    }} />
  </main>
  <Footer />
</Base>
