---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import Nav from "../../../components/Nav";
import Footer from "../../../components/Footer";

export async function getStaticPaths() {
  const jobs = await getCollection("jobs", ({ data }) => data.published);
  return jobs.map((job) => ({ params: { slug: job.slug }, props: { job } }));
}

const { job } = Astro.props;
const { Content } = await job.render();
const data = job.data;

const applyHref =
  data.applyUrl
    ? data.applyUrl
    : data.applyEmail
    ? `mailto:${data.applyEmail}?subject=${encodeURIComponent(`${data.title} Application`)}`
    : "mailto:careers@guardedgrowthip.com";

const postedFmt = data.posted.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const siteOrigin = (Astro.site?.toString() || "https://karanggip.github.io").replace(/\/$/, "");

const employmentTypeMap: Record<string, string> = {
  "Full-time":  "FULL_TIME",
  "Part-time":  "PART_TIME",
  "Contract":   "CONTRACTOR",
  "Internship": "INTERN",
};

const jobPostingLd = {
  "@context": "https://schema.org",
  "@type": "JobPosting",
  "title": data.title,
  "description": data.summary,
  "datePosted": data.posted.toISOString(),
  "employmentType": employmentTypeMap[data.type] || "FULL_TIME",
  "hiringOrganization": {
    "@type": "Organization",
    "name": "Guarded Growth IP",
    "sameAs": `${siteOrigin}${base}/`,
    "logo": `${siteOrigin}${base}/assets/icon-color.svg`,
  },
  "jobLocationType": data.location.toLowerCase().includes("remote") ? "TELECOMMUTE" : undefined,
  "applicantLocationRequirements": { "@type": "Country", "name": "US" },
  "jobLocation": {
    "@type": "Place",
    "address": { "@type": "PostalAddress", "addressLocality": "Austin", "addressRegion": "TX", "postalCode": "78731", "addressCountry": "US" },
  },
  "url": `${siteOrigin}${base}/company/careers/${job.slug}/`,
  "directApply": false,
};
---

<Base
  title={`${data.title} · Careers at Guarded Growth`}
  description={data.summary}
  jsonLd={jobPostingLd}
>
  <Nav client:load />

  <main style="background: #fff; color: #0C0C0E;">

    {/* Hero band */}
    <section style="padding-top: 120px; padding-bottom: 60px; position: relative; overflow: hidden; background: #050510;">
      <div style="position: absolute; width: 600px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(45,42,110,0.45) 0%, transparent 65%); top: -10%; left: 50%; transform: translateX(-50%); filter: blur(80px);"></div>
      <div class="grid-bg-animated" style="position: absolute; inset: 0;"></div>

      <div class="max-w-content mx-auto px-7 relative">
        <a href={import.meta.env.BASE_URL.replace(/\/$/, "") + "/company/careers/"}
          style="display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.5); text-decoration: none; margin-bottom: 24px; transition: color 0.2s;">
          ← All open roles
        </a>

        <div class="flex items-center gap-3 mb-4" style="flex-wrap: wrap;">
          <span style="font-size: 11px; font-weight: 700; padding: 4px 12px; border-radius: 9999px; background: rgba(91,127,255,0.12); color: #5B7FFF; border: 1px solid rgba(91,127,255,0.25); letter-spacing: 0.05em; text-transform: uppercase;">{data.department}</span>
          <span style="font-size: 12px; color: rgba(255,255,255,0.35); font-family: 'General Sans', sans-serif;">Posted {postedFmt}</span>
        </div>

        <h1 class="font-display font-extrabold text-white" style="font-size: clamp(34px, 4.5vw, 52px); letter-spacing: -0.04em; line-height: 1.05; margin-bottom: 16px; max-width: 820px;">
          {data.title}
        </h1>
        <p style="font-size: 17px; line-height: 1.7; color: rgba(255,255,255,0.55); max-width: 640px; font-family: 'General Sans', sans-serif; margin-bottom: 28px;">
          {data.summary}
        </p>

        <div style="display: flex; align-items: center; flex-wrap: wrap; gap: 24px; margin-bottom: 8px;">
          <span style="display: inline-flex; align-items: center; gap: 6px; font-size: 13px; color: rgba(255,255,255,0.6); font-family: 'General Sans', sans-serif;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5B7FFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
            {data.location}
          </span>
          <span style="display: inline-flex; align-items: center; gap: 6px; font-size: 13px; color: rgba(255,255,255,0.6); font-family: 'General Sans', sans-serif;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5B7FFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
            </svg>
            {data.type}
          </span>
        </div>
      </div>
    </section>

    {/* Body */}
    <article style="padding: 64px 28px;">
      <div style="max-width: 720px; margin: 0 auto;">
        <div class="job-body" style="font-family: 'General Sans', sans-serif;">
          <Content />
        </div>

        {/* Apply CTA */}
        <div id="apply-block" style="margin-top: 56px; padding: 32px 36px; border-radius: 16px; background: linear-gradient(135deg, #2D2A6E, #1e1b5e); color: #fff; text-align: center;">
          <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 22px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px;">Interested in this role?</h3>
          <p style="font-size: 14px; color: rgba(255,255,255,0.65); margin-bottom: 24px; font-family: 'General Sans', sans-serif; line-height: 1.65; max-width: 480px; margin-left: auto; margin-right: auto;">
            Send us a brief note about your background and why this role. We read every email and reply to anything that resonates.
          </p>
          <a href={applyHref}
            style="display: inline-flex; align-items: center; gap: 8px; padding: 13px 28px; border-radius: 10px; background: #fff; color: #2D2A6E; font-size: 14px; font-weight: 700; font-family: 'Plus Jakarta Sans', sans-serif; text-decoration: none; box-shadow: 0 4px 16px rgba(91,127,255,0.25);">
            Apply Now
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
      </div>
    </article>

    {/* Floating Apply Now button — visible while reading, fades when inline CTA scrolls into view */}
    <div id="floating-apply" style="position: fixed; left: 50%; bottom: 24px; transform: translateX(-50%) translateY(20px); opacity: 0; pointer-events: none; transition: opacity 0.3s cubic-bezier(0.16,1,0.3,1), transform 0.3s cubic-bezier(0.16,1,0.3,1); z-index: 900;">
      <a href={applyHref}
        style="display: inline-flex; align-items: center; gap: 10px; padding: 13px 26px; border-radius: 9999px; background: linear-gradient(135deg, #2D2A6E, #3D3A9E); color: #fff; font-size: 14px; font-weight: 700; font-family: 'Plus Jakarta Sans', sans-serif; text-decoration: none; box-shadow: 0 8px 24px rgba(45,42,110,0.35), 0 0 0 1px rgba(91,127,255,0.3);">
        Apply Now
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </main>

  <Footer />
</Base>

<style is:global>
  .job-body h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #0C0C0E;
    margin-top: 40px;
    margin-bottom: 16px;
    line-height: 1.2;
  }
  .job-body h2:first-child { margin-top: 0; }
  .job-body h3 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #0C0C0E;
    margin-top: 28px;
    margin-bottom: 12px;
  }
  .job-body p {
    font-size: 16px;
    line-height: 1.75;
    color: #5C5C6E;
    margin-bottom: 16px;
  }
  .job-body ul, .job-body ol {
    margin: 0 0 20px 24px;
    padding: 0;
  }
  .job-body li {
    font-size: 16px;
    line-height: 1.75;
    color: #5C5C6E;
    margin-bottom: 8px;
  }
  .job-body strong { color: #0C0C0E; font-weight: 600; }
  .job-body a { color: #5B7FFF; text-decoration: underline; }

  /* Visible state for floating Apply button (overrides inline styles) */
  #floating-apply.visible {
    opacity: 1 !important;
    transform: translateX(-50%) translateY(0) !important;
    pointer-events: auto !important;
  }
</style>

<script>
  // Show the floating Apply button when scrolled past the hero,
  // hide it when the inline Apply CTA enters the viewport (visual "merge").
  (function () {
    const floating = document.getElementById("floating-apply");
    const applyBlock = document.getElementById("apply-block");
    if (!floating || !applyBlock) return;

    let pastHero = false;
    let applyInView = false;

    function update() {
      // Show only when past hero AND the inline CTA is NOT yet in view
      if (pastHero && !applyInView) {
        floating.classList.add("visible");
      } else {
        floating.classList.remove("visible");
      }
    }

    // Track when user scrolls past 60vh (out of the hero region)
    function onScroll() {
      pastHero = window.scrollY > window.innerHeight * 0.5;
      update();
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    // Hide as soon as any part of the inline Apply block enters the viewport
    const obs = new IntersectionObserver(
      (entries) => {
        applyInView = entries[0].isIntersecting;
        update();
      },
      { rootMargin: "0px 0px -120px 0px", threshold: 0 }
    );
    obs.observe(applyBlock);
  })();
</script>
