---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav";
import Footer from "../components/Footer";
---

<Base
  title="Terms of Use · DocketEngine"
  description="Terms of Use for DocketEngine by Guarded Growth IP."
>
  <Nav client:load />

  <main style="background: #fff; color: #0C0C0E; min-height: 60vh;">
    <section style="padding-top: 120px; padding-bottom: 64px; background: #050510;">
      <div class="max-w-content mx-auto px-7">
        <span style="font-size: 12px; font-weight: 700; letter-spacing: 0.1em; color: #5B7FFF; text-transform: uppercase; display: block; margin-bottom: 16px;">Legal</span>
        <h1 class="font-display font-extrabold text-white" style="font-size: clamp(32px, 4vw, 48px); letter-spacing: -0.04em; line-height: 1.05;">
          Terms of Use — DocketEngine
        </h1>
      </div>
    </section>

    <section style="padding: 72px 28px;">
      <div style="max-width: 720px; margin: 0 auto; font-family: 'General Sans', sans-serif;">
        <div style="padding: 32px 36px; border-radius: 14px; background: #F6F6F9; border: 1px solid #E2E2EA; text-align: center;">
          <p style="font-size: 15px; line-height: 1.7; color: #5C5C6E; margin-bottom: 12px;">
            Our DocketEngine Terms of Use are being finalised and will be published here shortly.
          </p>
          <p style="font-size: 14px; line-height: 1.65; color: #8B8B9E;">
            In the meantime, please contact{" "}
            <a href="mailto:info@guardedgrowthip.com" style="color: #5B7FFF; font-weight: 600;">info@guardedgrowthip.com</a>{" "}
            with any questions about your use of the service.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
