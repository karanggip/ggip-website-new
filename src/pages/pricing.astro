---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav";
import Footer from "../components/Footer";
import PricingHero from "../components/pricing/PricingHero";
import PricingPlans from "../components/pricing/PricingPlans";
import RenewalPricing from "../components/pricing/RenewalPricing";
import PricingFAQ from "../components/pricing/PricingFAQ";
import PricingBottomCTA from "../components/pricing/PricingBottomCTA";
---

<Base
  title="Pricing · Transparent Plans That Scale With Your Practice"
  description="DocketEngine starts at $99/mo for up to 100 matters. RenewalEngine pricing based on portfolio. 14-day free trial. No hidden fees."
>
  <Nav client:load />
  <main>
    <PricingHero client:visible />
    <PricingPlans client:visible />
    <RenewalPricing client:visible />
    <PricingFAQ client:load />
    <PricingBottomCTA client:visible />
  </main>
  <Footer />
</Base>
