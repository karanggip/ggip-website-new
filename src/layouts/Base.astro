---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Guarded Growth · The Data Infrastructure for Global IP",
  description = "Modern IP management platform with automated docketing and renewals across 100+ jurisdictions. Purpose-built engines on a cloud-native data infrastructure.",
  ogImage = "/assets/og-default.png",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/assets/icon-color.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
