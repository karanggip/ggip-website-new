---
import "../styles/global.css";
import CookieBanner from "../components/CookieBanner";
import DemoModal from "../components/DemoModal";
import CareersModal from "../components/CareersModal";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article" | "product";
  noindex?: boolean;
  /** Additional schema.org JSON-LD objects for the current page (rendered alongside the
   *  global Organization + WebSite schemas that appear on every page). */
  jsonLd?: object | object[];
}

const {
  title = "Guarded Growth · The Data Infrastructure for Global IP",
  description = "Modern IP management platform with automated docketing and renewals across 100+ jurisdictions. Purpose-built engines on a cloud-native data infrastructure.",
  ogImage,
  ogType = "website",
  noindex = false,
  jsonLd,
} = Astro.props;

// Third-party loader IDs. Undefined values short-circuit the loader entirely,
// so dev / preview environments without these vars just don't load the scripts.
const GA_ID         = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const WHELP_APP_ID  = import.meta.env.PUBLIC_WHELP_APP_ID;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const faviconHref = `${base}/assets/icon-color.svg`;

// Build absolute canonical URL for the current page — always trailing-slashed
// (regardless of how the URL was requested) so search engines see one canonical form.
const siteOrigin = (Astro.site?.toString() || "https://karanggip.github.io").replace(/\/$/, "");
const pathname = Astro.url.pathname;
const lastSeg = pathname.split("/").filter(Boolean).pop() || "";
const canonicalPath = pathname.endsWith("/") || lastSeg.includes(".")
  ? pathname
  : `${pathname}/`;
const canonical = `${siteOrigin}${canonicalPath}`;
const ogImageUrl = ogImage
  ? (ogImage.startsWith("http") ? ogImage : `${siteOrigin}${base}${ogImage}`)
  : `${siteOrigin}${base}/assets/og-home.png`;

// Global schemas — present on every page
const organizationLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Guarded Growth IP",
  "legalName": "Guarded Growth IP LLC",
  "url": `${siteOrigin}${base}/`,
  "logo": `${siteOrigin}${base}/assets/icon-color.svg`,
  "email": "info@guardedgrowthip.com",
  "foundingDate": "2024",
  "description": "Modern IP management platform — the data infrastructure layer for global intellectual property.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "5900 Balcones Drive #28582",
    "addressLocality": "Austin",
    "addressRegion": "TX",
    "postalCode": "78731",
    "addressCountry": "US",
  },
  "founder": [
    { "@type": "Person", "name": "Valli S Challa", "jobTitle": "Co-founder, LegalOps & Program Management", "sameAs": "https://www.linkedin.com/in/vallischalla/" },
    { "@type": "Person", "name": "Karan S Kumar",  "jobTitle": "Co-founder, Product & Technology",         "sameAs": "https://www.linkedin.com/in/karanskumar/" },
  ],
};

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Guarded Growth IP",
  "url": `${siteOrigin}${base}/`,
  "publisher": { "@type": "Organization", "name": "Guarded Growth IP" },
};

const extraLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allLd = [organizationLd, websiteLd, ...extraLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    {/* Primary */}
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Open Graph */}
    <meta property="og:type"        content={ogType} />
    <meta property="og:site_name"   content="Guarded Growth IP" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:image"       content={ogImageUrl} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type"   content="image/png" />
    <meta property="og:locale"       content="en_US" />

    {/* Twitter */}
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageUrl} />

    {/* Favicons */}
    <link rel="icon"            type="image/svg+xml" href={faviconHref} />
    <link rel="apple-touch-icon" href={faviconHref} />

    {/* JSON-LD structured data */}
    {allLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
  </head>
  <body>
    <slot />
    <CookieBanner client:idle />
    <DemoModal client:idle />
    <CareersModal client:idle />

    {/* Google Analytics 4 — Consent Mode v2. Loads with everything denied by
        default and is upgraded to "granted" only when the user accepts the
        Analytics (or Marketing) category in the cookie banner. The CookieBanner
        component dispatches `cookie-consent` events that we listen to here. */}
    {GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){ dataLayer.push(arguments); }
          window.gtag = gtag;

          // Defaults: deny everything until consent is granted.
          gtag("consent", "default", {
            ad_storage: "denied",
            ad_user_data: "denied",
            ad_personalization: "denied",
            analytics_storage: "denied",
            wait_for_update: 500,
          });

          gtag("js", new Date());
          gtag("config", GA_ID, { anonymize_ip: true });

          function applyConsent(c) {
            gtag("consent", "update", {
              analytics_storage:  c.analytics ? "granted" : "denied",
              ad_storage:         c.marketing ? "granted" : "denied",
              ad_user_data:       c.marketing ? "granted" : "denied",
              ad_personalization: c.marketing ? "granted" : "denied",
            });
          }

          // Honor any existing choice the user already made.
          try {
            var raw = localStorage.getItem("ggip-cookie-consent");
            if (raw) {
              var parsed;
              if (raw === "accepted")      parsed = { analytics: true,  marketing: true  };
              else if (raw === "rejected") parsed = { analytics: false, marketing: false };
              else                         parsed = JSON.parse(raw);
              if (parsed) applyConsent(parsed);
            }
          } catch (e) { /* localStorage unavailable, leave defaults */ }

          // React to live changes from the cookie preferences panel.
          window.addEventListener("cookie-consent", function (e) {
            if (e && e.detail) applyConsent(e.detail);
          });
        </script>
      </>
    )}

    {/* Whelp live chat — always-on (treated as essential support tooling). */}
    {WHELP_APP_ID && (
      <script is:inline define:vars={{ WHELP_APP_ID }}>
        (function () {
          var s = document.createElement("script");
          s.src = "https://widget.whelp.co/app.js";
          s.async = true;
          s.onload = function () {
            if (typeof window.Whelp === "function") {
              window.Whelp("init", { app_id: WHELP_APP_ID });
            }
          };
          document.body.appendChild(s);
        })();
      </script>
    )}
  </body>
</html>
