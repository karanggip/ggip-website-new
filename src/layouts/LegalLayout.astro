---
import { getEntry } from "astro:content";
import Base from "./Base.astro";
import Nav from "../components/Nav";
import Footer from "../components/Footer";

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const entry = await getEntry("legal", slug);
if (!entry) {
  throw new Error(`Legal entry not found: ${slug}`);
}
const { Content } = await entry.render();
const data = entry.data;

const seoTitle = data.seoTitle || `${data.title} · Guarded Growth IP`;
const seoDescription = data.seoDescription || `${data.title} for Guarded Growth IP LLC.`;
---

<Base
  title={seoTitle}
  description={seoDescription}
>
  <Nav client:load />

  <main style="background: #fff; color: #0C0C0E;">

    {/* Hero */}
    <section style="padding-top: 120px; padding-bottom: 56px; position: relative; overflow: hidden; background: #050510;">
      <div style="position: absolute; width: 600px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(45,42,110,0.45) 0%, transparent 65%); top: -10%; left: 50%; transform: translateX(-50%); filter: blur(80px);"></div>
      <div class="grid-bg-animated" style="position: absolute; inset: 0;"></div>

      <div class="max-w-content mx-auto px-7 relative" style="max-width: 800px;">
        <span style="font-size: 12px; font-weight: 700; letter-spacing: 0.1em; color: #5B7FFF; text-transform: uppercase; display: block; margin-bottom: 16px;">Legal</span>
        <h1 class="font-display font-extrabold text-white" style="font-size: clamp(36px, 4.5vw, 52px); letter-spacing: -0.04em; line-height: 1.05; margin-bottom: 14px;">
          {data.title}
        </h1>
        {(data.subtitle || data.effectiveDate) && (
          <p style="font-size: 16px; color: rgba(255,255,255,0.55); font-family: 'General Sans', sans-serif;">
            {data.subtitle && <strong style="color: #fff; font-weight: 600;">{data.subtitle}</strong>}
            {data.subtitle && data.effectiveDate && <span>&nbsp;·&nbsp;</span>}
            {data.effectiveDate && <span>Effective Date: {data.effectiveDate}</span>}
          </p>
        )}
      </div>
    </section>

    {/* Body */}
    <article style="padding: 64px 28px;">
      <div class="legal-body" style="max-width: 760px; margin: 0 auto;">
        <Content />
      </div>
    </article>
  </main>

  <Footer />
</Base>

<style is:global>
  .legal-body { font-family: 'General Sans', sans-serif; color: #3D3D4E; }
  .legal-body h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: #0C0C0E;
    margin-top: 44px;
    margin-bottom: 14px;
    line-height: 1.25;
  }
  .legal-body h2:first-child { margin-top: 0; }
  .legal-body h3 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: #0C0C0E;
    margin-top: 26px;
    margin-bottom: 10px;
  }
  .legal-body p {
    font-size: 15px;
    line-height: 1.75;
    color: #3D3D4E;
    margin-bottom: 14px;
  }
  .legal-body ul, .legal-body ol {
    margin: 0 0 18px 22px;
    padding: 0;
  }
  .legal-body li {
    font-size: 15px;
    line-height: 1.7;
    color: #3D3D4E;
    margin-bottom: 8px;
  }
  .legal-body strong { color: #0C0C0E; font-weight: 600; }
  .legal-body a { color: #5B7FFF; text-decoration: underline; text-underline-offset: 3px; word-break: break-word; }
  /* Treat shouty-caps disclaimer paragraphs (15.1 / 15.2 / 15.3) gently */
  .legal-body p:has(strong:only-child),
  .legal-body p > strong:first-child { color: #0C0C0E; }
</style>
