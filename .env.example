# Copy this file to .env and fill in real values. .env is gitignored.
#
# Resend — server-side email delivery for /api/contact and /api/demo.
# Get a key at https://resend.com (free tier: 3000 emails/mo, 100/day).
# Required when site is deployed in SSR mode (Railway, hybrid output).
RESEND_API_KEY=
