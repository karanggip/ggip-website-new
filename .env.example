# Copy this file to .env and fill in real values. .env is gitignored.
# On Railway, set the same vars in the project's Variables tab.
#
# IMPORTANT: anything prefixed PUBLIC_ is exposed to the client bundle.
# Anything else stays server-only.

# Resend — server-side email delivery for /api/contact and /api/demo.
# Get a key at https://resend.com (free tier: 3000 emails/mo, 100/day).
RESEND_API_KEY=

# reCAPTCHA v3 — bot protection on form submissions.
# Generate at https://www.google.com/recaptcha/admin/create
PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Google Analytics 4 — measurement ID like G-XXXXXXXXXX.
# Loaded with Consent Mode v2; activated only when the Analytics cookie is granted.
PUBLIC_GA_MEASUREMENT_ID=

# Whelp live chat widget app_id (https://app.whelp.co → Settings → Channels).
# Loaded always-on (Essential category — treated as a support tool).
PUBLIC_WHELP_APP_ID=
